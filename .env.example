# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/game_lobby

# Server
PORT=3001
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5273

# Guest account cleanup (defaults: TTL 7d, sweep every 1h)
# GUEST_USER_TTL_MS=604800000
# GUEST_USER_SWEEP_INTERVAL_MS=3600000
# GUEST_USER_SWEEP_ON_START=true
# GUEST_USER_SWEEP_ENABLED=true

# Web (Vite) — leave unset to use same-origin + Vite proxy for /api and /socket.io
# VITE_API_URL=
# VITE_WS_URL=
